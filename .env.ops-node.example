# Template for the ops node's env file in the real three-node deployment
# (see docs/deployment.md). Copy to .env.ops-node directly on the ops node
# - never commit the real file, never reuse local .env's values.

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=changeme-use-a-real-generated-username
GRAFANA_ADMIN_PASSWORD=changeme-use-a-real-generated-secret
