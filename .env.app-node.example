# Template for the app node's env file in the real three-node deployment
# (see docs/deployment.md). Copy to .env.app-node directly on the app node
# - never commit the real file, never reuse local .env's values.
#
# POSTGRES_*/MINIO_* credentials here must match the data node's
# .env.data-node exactly - this node never runs those services itself, it
# only connects out to them over the private network.

# --- PostgreSQL (running on the data node) ---
POSTGRES_HOST=DATA_NODE_PRIVATE_IP
POSTGRES_PORT=5432
POSTGRES_DB=medimaging
POSTGRES_USER=medimaging
POSTGRES_PASSWORD=changeme-use-a-real-generated-secret

# --- MinIO (running on the data node) ---
MINIO_HOST=DATA_NODE_PRIVATE_IP
MINIO_ROOT_USER=changeme-use-a-real-generated-username
MINIO_ROOT_PASSWORD=changeme-use-a-real-generated-secret
MINIO_BUCKET=medimaging
MINIO_CONSOLE_PORT=9001

# --- Orthanc (running on the data node) ---
# Real credentials now, not reachability-check only (Step 29's DICOM
# pipeline demo calls Orthanc's own REST API directly).
ORTHANC_HOST=DATA_NODE_PRIVATE_IP
ORTHANC_HTTP_PORT=8042
ORTHANC_USER=orthanc
ORTHANC_PASSWORD=changeme-must-match-data-node

# --- FastAPI backend (this node) ---
API_PORT=8000
API_SECRET_KEY=changeme-use-a-real-generated-secret

# --- AI inference (this node, demo only, no clinical use) ---
AI_INFERENCE_PORT=8100

# --- Ops node (reachability checks only - Prometheus/Grafana run there) ---
PROMETHEUS_HOST=OPS_NODE_PRIVATE_IP
GRAFANA_HOST=OPS_NODE_PRIVATE_IP
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# --- Ops Dashboard public links (what a browser actually opens) ---
APP_NODE_HOST=APP_NODE_PUBLIC_IP
DATA_NODE_HOST=DATA_NODE_PUBLIC_IP
OPS_NODE_HOST=OPS_NODE_PUBLIC_IP
