# Template for a future production deployment (see docs/deployment.md).
# Copy this to .env.production directly on the target server - never commit
# the real file, and never reuse the local .env's values here. Every value
# below is still a placeholder; nothing here has ever been deployed.

# --- PostgreSQL ---
# Inside Docker Compose, services reach Postgres as "postgres", same as local.
POSTGRES_HOST=postgres
POSTGRES_USER=medimaging
POSTGRES_PASSWORD=changeme-use-a-real-generated-secret
POSTGRES_DB=medimaging
POSTGRES_PORT=5432

# --- MinIO ---
MINIO_HOST=minio
MINIO_ROOT_USER=changeme-use-a-real-generated-username
MINIO_ROOT_PASSWORD=changeme-use-a-real-generated-secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=medimaging

# --- Orthanc (DICOM server) ---
ORTHANC_HOST=orthanc
ORTHANC_HTTP_PORT=8042
ORTHANC_DICOM_PORT=4242
ORTHANC_USER=orthanc
ORTHANC_PASSWORD=changeme-use-a-real-generated-secret

# --- FastAPI backend ---
API_PORT=8000
# A real, randomly generated key, different from the local demo key - see
# docs/deployment.md's "Secrets handling" section. Still only a single
# shared key, same demo-grade limitation described in docs/security.md,
# just not the same value as local development uses.
API_SECRET_KEY=changeme-use-a-real-generated-secret

# --- AI inference (demo only, no clinical use) ---
AI_INFERENCE_PORT=8100

# --- Monitoring ---
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_USER=changeme-use-a-real-generated-username
GRAFANA_ADMIN_PASSWORD=changeme-use-a-real-generated-secret

# --- Reverse proxy / HTTPS (planned, not implemented - see docs/deployment.md) ---
# No domain is registered yet. Once one exists, it would go here so the
# reverse proxy config can reference it instead of a hardcoded name.
DEPLOYMENT_DOMAIN=not-set-yet.example.com
