# Copy this file to .env and fill in real values.
# Never commit the actual .env file.

# --- PostgreSQL ---
# POSTGRES_HOST is "localhost" for scripts run on the host machine (like the
# metadata extractor). Services inside Docker Compose reach it as "postgres" instead.
POSTGRES_HOST=localhost
POSTGRES_USER=medimaging
POSTGRES_PASSWORD=changeme
POSTGRES_DB=medimaging
POSTGRES_PORT=5432

# --- MinIO ---
# MINIO_HOST is "localhost" for scripts run on the host machine, same idea as POSTGRES_HOST/ORTHANC_HOST.
MINIO_HOST=localhost
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=medimaging

# --- Orthanc (DICOM server) ---
# ORTHANC_HOST is "localhost" for scripts run on the host machine, same idea as POSTGRES_HOST.
ORTHANC_HOST=localhost
ORTHANC_HTTP_PORT=8042
ORTHANC_DICOM_PORT=4242
ORTHANC_USER=orthanc
ORTHANC_PASSWORD=changeme

# --- FastAPI backend ---
API_PORT=8000
API_SECRET_KEY=changeme

# --- Monitoring ---
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
