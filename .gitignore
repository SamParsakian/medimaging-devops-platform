*.tmp
node_modules/

# --- IDE files ---
.vscode/
.idea/
*.swp
*.swo

# --- OS files ---
.DS_Store
Thumbs.db

# --- Screenshots (keep placeholder only) ---
screenshots/*
!screenshots/.gitkeep

# --- Local working notes (not part of tracked history) ---
worklog/
reports/
screenshots

# --- Downloaded sample DICOM files (fetched on demand, not stored in repo) ---
sample-data/*.dcm
sample-data/downloads/

# --- Generated anonymized DICOM output (not stored in repo) ---
services/anonymizer/output/
